#include <ESP32Servo.h>

Servo myservo;
int servoPin = 2;

void setup() {
  Serial.begin(115200); 
  myservo.setPeriodHertz(50); // PWM signal frequency for ESP32
  myservo.attach(servoPin, 500, 2400); // pulse width range for ESP32 (500 to 2400 us)
  Serial.println("System Starting");
  Serial.print("Enter an angle between 0 and 165: ");
}

void loop() {
  if (Serial.available() > 0) {
    int angle = Serial.parseInt();
    if (angle >= 0 && angle <= 165) 
    {
      Serial.println(angle);
      myservo.write(angle);
      Serial.print("Enter an angle between 0 and 165: ");
    }
    else
    {
      Serial.println();
      Serial.println("Invalid Input. Please input an angle between 0 and 165 degrees.");
      Serial.print("Enter angle between 0 and 165: ");
    }
  }
} 
